<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <Version>0.1.0.0</Version>
    <AssemblyVersion>0.1.0.0</AssemblyVersion>
    <FileVersion>0.1.0.0</FileVersion>
    <AssemblyName>SubtitleNexus</AssemblyName>
    <RootNamespace>SubtitleNexus</RootNamespace>
    <Authors>subtitlenexus</Authors>
    <Description>Generate AI subtitles via Subtitle Nexus (subtitlenexus.com)</Description>
    <RepositoryUrl>https://github.com/subtitlenexus/subtitlenexus-emby-plugin</RepositoryUrl>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Configuration\configPage.html" />
    <None Remove="thumb.png" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Configuration\configPage.html" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MediaBrowser.Server.Core" Version="4.9.1.90" />
  </ItemGroup>

</Project>
